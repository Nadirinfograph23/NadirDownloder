{
  "rewrites": [
    {
      "source": "/api/download",
      "destination": "/api/download"
    },
    {
      "source": "/api/stream",
      "destination": "/api/stream"
    }
  ],
  "functions": {
    "api/download.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/stream.js": {
      "maxDuration": 30
    }
  }
}
