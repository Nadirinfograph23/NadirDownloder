{
  "rewrites": [
    { "source": "/api/instagram", "destination": "/api/instagram" },
    { "source": "/api/download",   "destination": "/api/download"   },
    { "source": "/api/proxy",      "destination": "/api/proxy"      },
    { "source": "/api/thumbnail",  "destination": "/api/thumbnail"  },
    { "source": "/api/ig-download","destination": "/api/ig_download"}
  ],
  "functions": {
    "api/instagram.js": {
      "runtime": "@vercel/node@3.2.0",
      "maxDuration": 30
    },
    "api/download.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    },
    "api/proxy.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    },
    "api/thumbnail.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 10
    },
    "api/ig_download.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 60
    }
  }
}
